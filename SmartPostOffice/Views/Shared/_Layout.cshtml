<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Sri Lanka Post</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
   
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <div class="topbar">
        <div class="container d-flex justify-content-between">
            <span>
                <i class="bi bi-telephone-fill"></i>+94-112-328-301
                &nbsp;|&nbsp;
                <i class="bi bi-envelope-fill"></i>info@slpost.lk
            </span>
            <span>
                <i class="bi bi-clock-fill"></i>
                Mon – Fri: 8:00 AM – 5:00 PM &nbsp;|&nbsp;
                Sat: 8:00 AM – 12:00 PM
            </span>
        </div>
    </div>

    <header class="site-header">
        <div class="container d-flex align-items-center justify-content-between">
            <a href="/" class="brand-link d-flex align-items-center gap-3">
                <div class="brand-mark">📮</div>
                <div>
                    <div class="brand-title">Sri Lanka Post</div>
                    <div class="brand-sub">Smart Post Office Management System</div>
                </div>
            </a>
        </div>
    </header>

    <nav class="navbar navbar-expand-lg main-nav">
        <div class="container">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-fill me-1"></i>Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="ServiceRequest" asp-action="Create">
                            <i class="bi bi-plus-circle-fill me-1"></i>Request Services
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Tracking" asp-action="Track">
                            <i class="bi bi-geo-alt-fill me-1"></i>Track Services
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Bungalow">
                            <i class="bi bi-house-heart-fill me-1"></i>Book Bungalow
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Stamps">
                            <i class="bi bi-bookmark-fill me-1"></i>Book Stamps
                        </a>
                    </li>
                
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Counter" asp-action="Dashboard">
                        <i class="bi bi-speedometer2 me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Counter" asp-action="ProcessRequest">
                        <i class="bi bi-clipboard-check me-1"></i>Process Service
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Counter" asp-action="WalkIn">
                        <i class="bi bi-person-walking me-1"></i>Walk-in
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="CashBook" asp-action="Index">
                            <i class="bi bi-journal-text me-1"></i>Cash Book
                            </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="CashBook" asp-action="DailyReport">
                            <i class="bi bi-file-earmark-bar-graph me-1"></i>Daily Report
                       </a>
                    </li>

                    }
                    </ul>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="navbar-text me-3 fw-semibold" style="color:var(--sl-gold);">
                        <i class="bi bi-person-badge-fill me-1"></i>@User.Identity.Name
                    </span>
                    <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                    </a>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="btn ms-3"
                        style="background:var(--sl-gold); color:var(--sl-navy); font-weight:700;">
                        <i class="bi bi-person-badge-fill me-1"></i>Officer Login
                    </a>
                }
                
            </div>
        </div>
    </nav>

    <main class="main-content">
        <div class="container">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mt-3"
                     role="alert">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>@TempData["SuccessMessage"]</span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mt-3"
                     role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@TempData["ErrorMessage"]</span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="footer-top">
            <div class="container">
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="footer-logo d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-envelope-paper-fill"></i> Sri Lanka Post
                        </div>
                        <p class="footer-desc">
                            Serving Sri Lanka since 1798. Connecting communities
                            across all 9 provinces through 4,738 post offices island-wide.
                        </p>
                    </div>
                    <div class="col-md-2">
                        <div class="footer-heading">Services</div>
                        <ul class="footer-links">
                            <li><a href="#">Registered Post</a></li>
                            <li><a href="#">Speed Post</a></li>
                            <li><a href="#">Parcel Service</a></li>
                            <li><a href="#">Money Orders</a></li>
                        </ul>
                    </div>
                    <div class="col-md-2">
                        <div class="footer-heading">Support</div>
                        <ul class="footer-links">
                            <li><a href="#">Track Parcel</a></li>
                            <li><a href="#">Find Post Office</a></li>
                            <li><a href="#">Postage Rates</a></li>
                            <li><a href="#">FAQ</a></li>
                        </ul>
                    </div>
                    <div class="col-md-4">
                        <div class="footer-heading">Contact Us</div>
                        <ul class="footer-contact">
                            <li>
                                <i class="bi bi-geo-alt-fill"></i>
                                310, D.R. Wijewardena Mawatha, Colombo 01000
                            </li>
                            <li>
                                <i class="bi bi-telephone-fill"></i>
                                +94-112-328-301
                            </li>
                            <li>
                                <i class="bi bi-envelope-fill"></i>
                                info@slpost.lk
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container d-flex justify-content-between flex-wrap gap-2">
                <span>&copy; @DateTime.Now.Year Sri Lanka Post — Department of Posts</span>
                <span>Smart Post Office Management System</span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>