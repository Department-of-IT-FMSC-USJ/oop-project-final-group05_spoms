@model string
@{
    ViewData["Title"] = "Request Submitted";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-7 col-lg-6">

        <div class="text-center mb-4">
            <div style="width:80px; height:80px; background: var(--sl-success-bg);
                        border-radius:50%; display:flex; align-items:center;
                        justify-content:center; margin: 0 auto 16px; font-size: 38px;">
                ✅
            </div>
            <h1 style="font-size:26px;">Request Submitted Successfully!</h1>
            <p class="text-muted">
                Your postal service request has been received and is now pending processing.
            </p>
        </div>
        <div class="ref-box mb-4">
            <div class="ref-label">Your Reference Number</div>
            <div class="ref-number">@Model</div>
            <div class="ref-note">
                Please save or screenshot this number. Bring it to your nearest
                post office counter to process your service request.
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header light">
                <i class="bi bi-info-circle-fill text-sl-red"></i> Request Status
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted" style="font-size:13.5px;">Current Status</span>
                    <span class="badge-pending">⏳ PENDING</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted" style="font-size:13.5px;">Submitted On</span>
                    <span class="fw-600" style="font-size:13.5px;">@DateTime.Now.ToString("dd MMM yyyy, hh:mm tt")</span>
                </div>
                <hr class="divider-red" />
                <div class="alert alert-warning d-flex gap-2 align-items-start mb-0" style="font-size:13px;">
                    <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
                    <span>
                        Visit any Sri Lanka Post office with this reference number within
                        <strong>7 working days</strong> to complete your request.
                    </span>
                </div>
            </div>
        </div>

        <div class="d-flex gap-3 justify-content-center">
            <a href="/ServiceRequest/Create" class="btn btn-primary btn-lg">
                <i class="bi bi-plus-circle-fill me-2"></i>Submit Another Request
            </a>
            <a href="/" class="btn btn-outline-secondary btn-lg">
                <i class="bi bi-house-fill me-1"></i>Back to Home
            </a>
        </div>

    </div>
</div>