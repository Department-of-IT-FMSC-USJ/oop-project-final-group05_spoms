@{
    ViewData["Title"] = "Secure Payment";
    var amount = (decimal)ViewBag.Amount;
    var reference = (string)ViewBag.Reference;
    var serviceLabel = (string)ViewBag.ServiceLabel;
    var bookingId = (int)ViewBag.BookingId;
    var module = (string)ViewBag.Module; // "Bungalow" | "Stamp" | "Telemail"
    var postAction = $"/{module}/Pay";
}

@if (TempData["PaymentError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["PaymentError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">

        <div class="card mb-4" style="border:2px solid var(--sl-navy);">
            <div class="card-header text-white" style="background:var(--sl-navy);">
                <i class="bi bi-receipt me-2"></i>Order Summary
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="fw-semibold text-muted">Service</span>
                    <span>@serviceLabel</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span class="fw-semibold text-muted">Reference No.</span>
                    <span class="fw-bold" style="color:var(--sl-navy);">@reference</span>
                </div>
                <hr class="my-2" />
                <div class="d-flex justify-content-between fs-5 fw-bold">
                    <span>Total Amount</span>
                    <span style="color:var(--sl-red);">LKR @amount.ToString("N2")</span>
                </div>
            </div>
        </div>

        <div class="card shadow">
            <div class="card-header fw-bold" style="background:var(--sl-gold); color:var(--sl-navy);">
                <i class="bi bi-credit-card-2-front-fill me-2"></i>Enter Card Details
            </div>
            <div class="card-body">
                <form method="post" action="@postAction" id="payForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="bookingId" value="@bookingId" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Card Holder Name</label>
                        <input name="cardHolderName" class="form-control" placeholder="As printed on card" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Card Number</label>
                        <input name="cardNumber" id="cardNum" class="form-control" placeholder="1234 5678 9012 3456"
                               maxlength="19" required />
                        <div id="cardType" class="mt-1 small text-muted"></div>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold">Expiry Date</label>
                            <input name="expiryDate" class="form-control" placeholder="MM / YY" maxlength="7"
                                   required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold">CVV</label>
                            <input name="cvv" type="password" class="form-control" placeholder="•••" maxlength="4"
                                   required />
                        </div>
                    </div>

                    <div class="d-grid mt-2">
                        <button type="submit" id="payBtn" class="btn btn-lg fw-bold"
                                style="background:var(--sl-navy); color:white;">
                            <i class="bi bi-shield-lock-fill me-2"></i>
                            Pay LKR @amount.ToString("N2") Securely
                        </button>
                    </div>
                </form>

                <div class="text-center mt-3">
                    <small class="text-muted">
                        <i class="bi bi-lock-fill me-1"></i>256-bit SSL Encrypted · Sri Lanka Post Secure Payment
                    </small>
                </div>
                <div class="text-center mt-2">
                    <span class="badge bg-secondary me-1">VISA</span>
                    <span class="badge bg-secondary me-1">MASTERCARD</span>
                    <span class="badge bg-secondary me-1">AMEX</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>

        document.getElementById('cardNum').addEventListener('input', function () {
            let v = this.value.replace(/\D/g, '').substring(0, 16);
            this.value = v.replace(/(\d{4})(?=\d)/g, '$1 ');
            const t = document.getElementById('cardType');
            if (v.startsWith('4')) t.textContent = '💳 Visa';
            else if (v.startsWith('5')) t.textContent = '💳 Mastercard';
            else if (v.startsWith('3')) t.textContent = '💳 American Express';
            else t.textContent = '';
        });

        document.getElementById('payForm').addEventListener('submit', function () {
            const btn = document.getElementById('payBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing...';
        });
    </script>
}