
@{
    ViewData["Title"] = "Home";
}

<div class="hero-banner mt-2">
    <center><div class="hero-badge">Official Government Service</div>
    <h1>Smart Post Office</h1>
    <p>Fast, reliable postal services across Sri Lanka. Submit your request online and collect at any post office island-wide.</p>
    <a href="/ServiceRequest/Create" class="btn btn-warning btn-lg fw-bold me-2">
        <i class="bi bi-plus-circle-fill me-2"></i>Request a Service
    </a>
    <a href="/Track" class="btn btn-outline-light btn-lg">
        <i class="bi bi-search me-2"></i>Track Parcel
    </a>
    </center>
    </div>

<div class="d-flex align-items-center gap-3 mb-4">
    <h2 class="mb-0">Our Services</h2>
    <div class="flex-grow-1 divider-red"></div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-6 col-lg-3">
        <a href="/ServiceRequest/Create" class="service-card" style="border-color: var(--sl-red);">
            <div class="svc-icon" style="background: var(--sl-red); color: white;">
                <i class="bi bi-box-seam-fill"></i>
            </div>
            <h5>Request Services</h5>
            <p>Send letters, parcels, speed post and registered mail island-wide.</p>
            <span class="svc-btn filled">Request Now</span>
        </a>
    </div>

      <div class="col-md-6 col-lg-3">
        <a href="/Track" class="service-card">
            <div class="svc-icon">
                <i class="bi bi-geo-alt-fill"></i>
            </div>
            <h5>Track Services</h5>
            <p>Track your parcel in real-time using your reference number or barcode.</p>
            <span class="svc-btn outline">Track Now</span>
        </a>
    </div>

    <div class="col-md-6 col-lg-3">
        <a href="/Bungalow" class="service-card">
            <div class="svc-icon">
                <i class="bi bi-house-heart-fill"></i>
            </div>
            <h5>Book Bungalow</h5>
            <p>Reserve post office holiday bungalows at scenic locations island-wide.</p>
            <span class="svc-btn outline">Book Now</span>
        </a>
    </div>

    <div class="col-md-6 col-lg-3">
        <a href="/Stamp" class="service-card">
            <div class="svc-icon">
                <i class="bi bi-bookmark-star-fill"></i>
            </div>
            <h5>Book Stamps</h5>
            <p>Order commemorative and regular postage stamps for collectors and businesses.</p>
            <span class="svc-btn outline" >Order Now</a></span>
        </a>
    </div>

</div>


<div class="row g-3 mb-2">
    <div class="col-md-4">
        <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: var(--sl-white); border: 1px solid var(--sl-border);">
            <div class="fs-2 text-sl-red"><i class="bi bi-buildings-fill"></i></div>
            <div>
                <div class="fw-bold text-sl-navy">4,738</div>
                <div class="text-muted" style="font-size:13px;">Post Offices Island-wide</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: var(--sl-white); border: 1px solid var(--sl-border);">
            <div class="fs-2 text-sl-red"><i class="bi bi-clock-history"></i></div>
            <div>
                <div class="fw-bold text-sl-navy">Since 1798</div>
                <div class="text-muted" style="font-size:13px;">Trusted for Over 225 Years</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: var(--sl-white); border: 1px solid var(--sl-border);">
            <div class="fs-2 text-sl-red"><i class="bi bi-shield-check-fill"></i></div>
            <div>
                <div class="fw-bold text-sl-navy">100% Secure</div>
                <div class="text-muted" style="font-size:13px;">Government Certified Service</div>
            </div>
        </div>
    </div>
</div>