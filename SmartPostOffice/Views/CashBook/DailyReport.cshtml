@model List<SmartPostOffice.Models.CashBookEntry>
@{
    ViewData["Title"] = "Daily Remittance Report — " + ViewBag.ReportDate;
}

@section Styles {
    <style>
        @@media print {
            .no-print {
                display: none !important;
            }
        }
    </style>
}

<div class="no-print d-flex gap-2 mb-4">
    <button onclick="window.print()" class="btn btn-primary">
        <i class="bi bi-printer-fill me-2"></i>Print Report
    </button>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Cash Book
    </a>
</div>

<div class="text-center mb-4">
    <h3 style="color:var(--sl-navy);">Sri Lanka Post</h3>
    <h4>DAILY REMITTANCE REPORT</h4>
    <p class="text-muted">Date: <strong>@ViewBag.ReportDate</strong></p>
</div>

<table class="table table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Register</th>
            <th class="text-center">Entries</th>
            <th class="text-end">Cash (LKR)</th>
            <th class="text-end">Online (LKR)</th>
            <th class="text-end">Register Total (LKR)</th>
            <th class="text-center">Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var reg in (IEnumerable<dynamic>)ViewBag.Registers)
        {
            string rowClass = reg.Balance == null ? "" :
                reg.Balance.Status == "BALANCED" ? "table-success" : "table-warning";
            <tr class="@rowClass">
                <td><strong>@reg.RegisterName</strong></td>
                <td class="text-center">@reg.Count</td>
                <td class="text-end">@((decimal)reg.CashTotal).ToString("N2")</td>
                <td class="text-end">@((decimal)reg.OnlineTotal).ToString("N2")</td>
                <td class="text-end fw-bold">@((decimal)reg.Total).ToString("N2")</td>
                <td class="text-center">
                    @if (reg.Balance == null)
                    {
                        <span class="badge bg-secondary">Not Closed</span>
                    }
                    else if (reg.Balance.Status == "BALANCED")
                    {

                        <span class="badge bg-success">✅ Balanced</span>
                    }
                    else
                    {

                        <span class="badge bg-warning text-dark">⚠️ Discrepancy</span>
                    }
                </td>
            </tr>
        }
    </tbody>
    <tfoot class="table-dark">
        <tr>
            <td><strong>Grand Total</strong></td>
            <td class="text-center">@Model.Count</td>
            <td class="text-end fw-bold">@ViewBag.GrandCash.ToString("N2")</td>
            <td class="text-end fw-bold">@ViewBag.GrandOnline.ToString("N2")</td>
            <td class="text-end fw-bold">@ViewBag.GrandTotal.ToString("N2")</td>
            <td class="text-center">
                @if (((List<SmartPostOffice.Models.DayBalance>)ViewBag.AllBalances).Count == 5)
                {
                    <span class="badge bg-success">All Closed</span>
                }
                else
                {

                    <span class="badge bg-secondary">Partial</span>
                }
            </td>
        </tr>
    </tfoot>
</table>

@{
    var discrepancies = ((List<SmartPostOffice.Models.DayBalance>)ViewBag.AllBalances)
    .Where(b => b.Status == "DISCREPANCY").ToList();
}
@if (discrepancies.Any())
{
    <div class="alert alert-warning mt-3">
        <strong>⚠️ Discrepancies Recorded</strong>
        <ul class="mb-0 mt-2">
            @foreach (var b in discrepancies)
            {
                <li>
                    @CashBookController.GetRegisterName((SmartPostOffice.Models.Enums.ServiceType)b.ServiceType)
                    System LKR @b.SystemCashTotal.ToString("N2") vs
                    Physical LKR @b.PhysicalCashCounted.ToString("N2") =
                    <strong>LKR @Math.Abs(b.Discrepancy).ToString("N2") difference</strong>
                </li>
            }
        </ul>
    </div>
}

<p class="text-muted text-center mt-4" style="font-size:11px;">
    Generated by Smart Post Office Management System (SPOMS) — Group 05
</p>