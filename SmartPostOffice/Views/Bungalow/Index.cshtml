@using SmartPostOffice.Models
@model dynamic

@{
    ViewData["Title"] = "Book a Holiday Bungalow";
    bool isOfficer = User.Identity?.IsAuthenticated == true && User.HasClaim(c => c.Type == "OfficerId");
}

@if (isOfficer)
{
    <div class="p-4 mb-4 rounded text-white" style="background:var(--sl-navy);">
        <h2><i class="bi bi-house-check-fill me-2"></i>Bungalow Booking Details</h2>
        <p class="mb-0">Manage and view all bungalow reservations made by customers.</p>
    </div>

    
            <div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead style="background:var(--sl-navy); color:white;">
                <tr>
                    <th style="width: 25%;">Guest Name</th>
                    <th style="width: 20%;">NIC & Contact</th>
                    <th style="width: 25%;">Location & Room</th>
                    <th style="width: 15%;">Status</th>
                    <th style="width: 15%;">Total Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in (IEnumerable<BungalowBooking>)Model)
                {
                    <tr>
                        
                        <td class="fw-bold text-primary text-uppercase">
                            @item.GuestName
                        </td>

                        
                        <td>
                            <div class="fw-semibold">@item.NIC</div>
                            <small class="text-muted"><i class="bi bi-telephone-fill me-1"></i>@item.Phone</small>
                        </td>

                        
                        <td>
                            <div class="fw-semibold">@item.Location</div>
                            <small class="text-muted">
                                @item.RoomOption (@item.Nights @(item.Nights > 1 ? "Nights" : "Night"))
                            </small>
                        </td>

                        
                        <td>
                            @if (item.PaymentStatus == "Paid")
                            {
                                <span class="badge bg-success px-3 py-2">
                                    <i class="bi bi-check-circle-fill me-1"></i> Paid
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark px-3 py-2">
                                    <i class="bi bi-clock-history me-1"></i> @item.PaymentStatus
                                </span>
                            }
                        </td>

                        
                        <td class="fw-bold text-success">
                            LKR @item.CalculateTotal().ToString("N2")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
        
   
}
else
{



<div class="p-4 mb-4 rounded text-white" style="background:var(--sl-navy);">
  <h2><i class="bi bi-house-heart-fill me-2"></i>Sri Lanka Post — Postal Holiday Homes</h2>
  <p class="mb-0">Book a postal bungalow across Sri Lanka. Payment is completed online before your stay.</p>
</div>

<div class="row g-4">
  @foreach (var loc in Model)
  {
    <div class="col-md-4">
      <div class="card h-100 shadow-sm" style="border-top:4px solid var(--sl-navy);">
        <div class="card-header" style="background:var(--sl-navy); color:white;">
          <div class="d-flex align-items-center gap-2">
            <span style="font-size:1.6rem;">@loc.Emoji</span>
            <div>
              <div class="fw-bold">@loc.Name</div>
              <small style="color:var(--sl-gold);">@loc.Province Province</small>
            </div>
          </div>
        </div>
        <div class="card-body">
          <p class="text-muted small mb-2">@loc.Description</p>
          <table class="table table-sm table-bordered mb-1">
            <thead class="table-dark"><tr><th>Room</th><th>Outsider</th><th>Staff</th><th>Max</th></tr></thead>
            <tbody>
              @foreach (var r in loc.Rooms)
              {
                <tr>
                  <td class="small">@r.RoomLabel</td>
                  <td class="fw-bold" style="color:var(--sl-red);">LKR @r.OutsiderRate.ToString("N0")</td>
                  <td class="small">@(r.StaffRate > 0 ? "LKR " + r.StaffRate.ToString("N0") : "N/A")</td>
                  <td>@r.MaxGuests</td>
                </tr>
              }
            </tbody>
          </table>
          <small class="text-muted">+ LKR 300 service charge · Tel: @loc.Phone</small>
        </div>
        <div class="card-footer">
          <a asp-action="Book" asp-route-locationId="@loc.Id" class="btn w-100 fw-bold"
             style="background:var(--sl-gold); color:var(--sl-navy);">
            <i class="bi bi-calendar-check-fill me-1"></i>Book Now
          </a>
        </div>
      </div>
    </div>
  }
</div>
}
